# --- Langfuse credentials (read directly by the langfuse SDK) ---
# Get these from your Langfuse project settings (Cloud or self-hosted).
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Host of your Langfuse instance.
#   - Langfuse Cloud (EU): https://cloud.langfuse.com  (this is the default if unset)
#   - Langfuse Cloud (US): https://us.cloud.langfuse.com
#   - Self-hosted:         https://langfuse.your-domain.com
# LANGFUSE_BASE_URL is the current variable. LANGFUSE_HOST is a deprecated alias
# that the SDK still honors; prefer LANGFUSE_BASE_URL.
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- langfuse_wrapper toggles ---
# Master on/off switch for this wrapper. When false (or when keys are missing),
# every trace/span/generation/score call becomes a safe no-op and the host app
# runs unchanged. Defaults to true.
LFWRAP_ENABLED=true

# When true, input/output payloads are PII-scrubbed before being sent to Langfuse.
# Defaults to false.
LFWRAP_SCRUB_PII=false
